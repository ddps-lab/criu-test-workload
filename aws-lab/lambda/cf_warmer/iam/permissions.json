{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListCheckpointsBucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::mhsong-criu-checkpoints",
        "arn:aws:s3:::mhsong-criu-data-artifact"
      ]
    },
    {
      "Sid": "ReadCheckpointsObjects",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": [
        "arn:aws:s3:::mhsong-criu-checkpoints/*",
        "arn:aws:s3:::mhsong-criu-data-artifact/*"
      ]
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    },
    {
      "Sid": "SelfInvokeForDispatch",
      "Effect": "Allow",
      "Action": ["lambda:InvokeFunction"],
      "Resource": "arn:aws:lambda:*:*:function:cf_warmer*"
    }
  ]
}
